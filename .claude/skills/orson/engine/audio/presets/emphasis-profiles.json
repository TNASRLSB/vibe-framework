{
  "_doc": "Prosody profiles for different element types in narration",

  "profiles": {
    "heading": {
      "rate": "-15%",
      "pitch": "+5Hz",
      "suffix": "!!",
      "description": "Slower, higher pitch for emphasis on headlines"
    },
    "subheading": {
      "rate": "-10%",
      "pitch": "+3Hz",
      "suffix": "!",
      "description": "Moderate emphasis for secondary headings"
    },
    "text": {
      "rate": "+0%",
      "pitch": "+0Hz",
      "suffix": "",
      "description": "Normal reading speed for body text"
    },
    "button": {
      "rate": "-10%",
      "pitch": "+8Hz",
      "suffix": "!!",
      "description": "Call-to-action emphasis"
    },
    "cta": {
      "rate": "-15%",
      "pitch": "+10Hz",
      "suffix": "!!",
      "description": "Strong emphasis for final CTA"
    },
    "stat": {
      "rate": "-5%",
      "pitch": "+2Hz",
      "suffix": "",
      "description": "Slight emphasis for statistics"
    },
    "quote": {
      "rate": "-5%",
      "pitch": "-2Hz",
      "suffix": "",
      "description": "Slightly slower, lower pitch for quotes"
    }
  },

  "styles": {
    "enthusiastic": {
      "base_rate": "+5%",
      "base_pitch": "+3Hz",
      "description": "Upbeat, energetic delivery"
    },
    "neutral": {
      "base_rate": "+0%",
      "base_pitch": "+0Hz",
      "description": "Standard professional delivery"
    },
    "calm": {
      "base_rate": "-10%",
      "base_pitch": "-2Hz",
      "description": "Relaxed, measured delivery"
    },
    "dramatic": {
      "base_rate": "-15%",
      "base_pitch": "+0Hz",
      "description": "Slow, impactful delivery"
    }
  },

  "text_transformations": {
    "numbers_to_words": {
      "50%": "fifty percent",
      "100%": "one hundred percent",
      "1000+": "over a thousand",
      "24/7": "twenty-four seven",
      "3x": "three times",
      "10x": "ten times"
    },
    "acronyms": {
      "AI": "A.I.",
      "API": "A.P.I.",
      "SaaS": "sass",
      "B2B": "B to B",
      "B2C": "B to C",
      "ROI": "R.O.I.",
      "UI": "U.I.",
      "UX": "U.X."
    },
    "punctuation_emotion": {
      "!!": "Strong emphasis, excitement",
      "...": "Pause, suspense",
      "!": "Light emphasis"
    }
  },

  "template_style_mapping": {
    "tech_promo": "enthusiastic",
    "epic_trailer": "dramatic",
    "chill_lifestyle": "calm",
    "corporate_safe": "neutral",
    "hype_social": "enthusiastic",
    "luxury_minimal": "calm"
  }
}
