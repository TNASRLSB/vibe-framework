  "style_selection_algorithm": {
    "description": "Deterministic style selection using feature vector from video context",
    "steps": [
      "1. Determine mode from video config",
      "2. Filter styles by mode_mapping[mode].soundtrack_styles",
      "3. Match context tags to style.contexts",
      "4. Match energy level to style.energy",
      "5. If multiple matches, pick lowest priority number",
      "6. Fallback: corporate (safe/hybrid) or electronic (chaos) or upbeat (cocomelon)"
    ]
  }
