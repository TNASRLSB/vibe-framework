{
  "style": "corporate",
  "description": "Clean, professional background music with piano and soft pads for business presentations and explainer videos.",
  "family": "tonal",
  "temporal": {
    "bpm": 90,
    "range": [80, 100],
    "swing": 0,
    "timeSignature": [4, 4],
    "endingBehavior": {
      "type": "cadential_insert",
      "cadenceBars": 2,
      "forceTonicLastBar": true,
      "maxTempoDeviationPercent": 5
    }
  },
  "key": "C major",
  "instruments": {
    "piano": {
      "type": "PolySynth",
      "config": {
        "voice": "Synth",
        "maxPolyphony": 6,
        "options": {
          "oscillator": { "type": "triangle8" },
          "envelope": { "attack": 0.01, "decay": 0.8, "sustain": 0.2, "release": 1.2 }
        }
      },
      "volume": -18,
      "range": ["A1", "C7"],
      "optimal_range": ["F2", "C6"],
      "effects": [
        { "type": "Reverb", "config": { "decay": 2.5, "wet": 0.3 } }
      ]
    },
    "pad": {
      "type": "PolySynth",
      "config": {
        "voice": "FMSynth",
        "maxPolyphony": 4,
        "options": {
          "harmonicity": 1.5,
          "modulationIndex": 1,
          "oscillator": { "type": "sine" },
          "modulation": { "type": "sine" },
          "envelope": { "attack": 1.5, "decay": 0.3, "sustain": 0.8, "release": 3.0 },
          "modulationEnvelope": { "attack": 2.0, "decay": 0.5, "sustain": 0.4, "release": 2.0 }
        }
      },
      "volume": -22,
      "range": ["C2", "C6"],
      "optimal_range": ["C3", "C5"],
      "effects": [
        { "type": "Chorus", "config": { "frequency": 0.5, "delayTime": 3.5, "depth": 0.6, "wet": 0.3 } },
        { "type": "Reverb", "config": { "decay": 4.0, "wet": 0.45 } }
      ]
    },
    "strings": {
      "type": "PolySynth",
      "config": {
        "voice": "AMSynth",
        "maxPolyphony": 4,
        "options": {
          "harmonicity": 2,
          "oscillator": { "type": "sawtooth4" },
          "modulation": { "type": "sine" },
          "envelope": { "attack": 1.0, "decay": 0.5, "sustain": 0.7, "release": 2.5 },
          "modulationEnvelope": { "attack": 1.5, "decay": 0.5, "sustain": 0.6, "release": 2.0 }
        }
      },
      "volume": -14,
      "range": ["G3", "E6"],
      "optimal_range": ["G3", "D6"],
      "effects": [
        { "type": "Filter", "config": { "frequency": 2000, "type": "lowpass", "rolloff": -12 } },
        { "type": "Reverb", "config": { "decay": 3.5, "wet": 0.4 } }
      ]
    },
    "bass": {
      "type": "MonoSynth",
      "config": {
        "oscillator": { "type": "triangle" },
        "envelope": { "attack": 0.05, "decay": 0.3, "sustain": 0.6, "release": 0.8 },
        "filterEnvelope": { "attack": 0.06, "decay": 0.2, "sustain": 0.5, "release": 0.8, "baseFrequency": 200, "octaves": 1.5 }
      },
      "volume": -15,
      "range": ["E1", "G3"],
      "optimal_range": ["E1", "E3"],
      "effects": []
    }
  },
  "master": {
    "effects": [
      { "type": "EQ3", "config": { "low": 1, "mid": 0, "high": -2 } },
      { "type": "Compressor", "config": { "threshold": -14, "ratio": 3, "attack": 0.05, "release": 0.2 } },
      { "type": "Filter", "config": { "frequency": 16000, "type": "lowpass", "rolloff": -12 } },
        { "type": "Limiter", "config": { "threshold": -3 } }
    ]
  },
  "progression": {
    "chords": ["I", "V", "vi", "IV"],
    "scale": "major",
    "bars_per_chord": 2
  },
  "harmonic_system": {
    "type": "functional_tonal",
    "functions": {
      "I": "T",
      "V": "D",
      "vi": "T(relative)",
      "IV": "SD"
    },
    "cadences": {
      "primary": "plagal",
      "reasoning": "Last chord IV resolving back to I = plagal cadence"
    }
  },
  "arc": {
    "intro": { "layers": ["pad"], "velocity": 0.4 },
    "build": { "layers": ["pad", "piano", "bass"], "velocity": 0.55 },
    "climax": { "layers": ["pad", "piano", "bass", "strings"], "velocity": 0.75 },
    "resolve": { "layers": ["pad", "piano"], "velocity": 0.35 }
  },
  "orchestration_limits": {
    "intro": { "max_simultaneous_voices": 1 },
    "build": { "max_simultaneous_voices": 3 },
    "climax": { "max_simultaneous_voices": 4 },
    "resolve": { "max_simultaneous_voices": 2 },
    "hard_limit": 6,
    "spectral_rule": "If 4+ active voices, at least one must be 'light' (high freq, little low content)"
  },
  "form": {
    "type": "periodo_tematico",
    "phrases": [
      { "role": "antecedent", "cadence": "half" },
      { "role": "consequent", "cadence": "plagal" }
    ],
    "development": {
      "climax": "repetition_with_added_layers",
      "resolve": "consequent_simplified"
    }
  },
  "rhythmGrid": {
    "_doc": "16-step velocity arrays. Corporate has no dedicated drum instruments; rhythm is implied by piano/bass attack patterns. Grid is intentionally sparse — only light accents on piano and bass.",
    "intro": {},
    "build": {
      "bass": [0.5, 0, 0, 0, 0, 0, 0, 0, 0.3, 0, 0, 0, 0, 0, 0, 0]
    },
    "climax": {
      "bass": [0.6, 0, 0, 0, 0, 0, 0, 0, 0.4, 0, 0, 0, 0.3, 0, 0, 0]
    },
    "resolve": {}
  },
  "voiceLeading": {
    "_doc": "Concrete voicings for C major: I=C, V=G, vi=Am, IV=F",
    "chords": {
      "C": {
        "root":   ["C3", "G3", "C4", "E4", "G4"],
        "drop2":  ["C3", "G3", "E4", "G4", "C5"],
        "spread": ["C3", "C4", "G4", "E5"]
      },
      "G": {
        "root":   ["G2", "D3", "G3", "B3", "D4"],
        "drop2":  ["G2", "D3", "B3", "D4", "G4"],
        "spread": ["G2", "G3", "D4", "B4"]
      },
      "Am": {
        "root":   ["A2", "E3", "A3", "C4", "E4"],
        "drop2":  ["A2", "E3", "C4", "E4", "A4"],
        "spread": ["A2", "A3", "E4", "C5"]
      },
      "F": {
        "root":   ["F2", "C3", "F3", "A3", "C4"],
        "drop2":  ["F2", "C3", "A3", "C4", "F4"],
        "spread": ["F2", "F3", "C4", "A4"]
      }
    },
    "transitions": {
      "C_to_G":  { "motion": "bass descends fourth, E4 holds as common tone, top voice B3→D4", "parallel_motion_check": "no parallel P5 or P8" },
      "G_to_Am": { "motion": "bass moves up step G→A, B3→C4, D4→E4 — smooth ascending", "parallel_motion_check": "no parallel P5 or P8" },
      "Am_to_F": { "motion": "bass descends third A→F, C4→C4 common tone, E4→A3 inner drop", "parallel_motion_check": "no parallel P5 or P8" },
      "F_to_C":  { "motion": "bass ascends fifth F→C, A3→G3, voices converge to root position", "parallel_motion_check": "no parallel P5 or P8" }
    },
    "arc_voicing": {
      "intro": "spread",
      "build": "drop2",
      "climax": "root",
      "resolve": "spread"
    }
  },
  "melodicPatterns": {
    "piano": {
      "intro":  { "pattern": "whole_notes", "voicing": "spread", "octave": 4 },
      "build":  { "pattern": "quarter_note_arpeggiate", "voicing": "drop2", "octave": 4 },
      "climax": { "pattern": "eighth_note_arpeggiate", "voicing": "root", "octave": 4 },
      "resolve":{ "pattern": "whole_notes", "voicing": "spread", "octave": 4 }
    },
    "bass": {
      "intro":  { "pattern": "silent" },
      "build":  { "pattern": "whole_notes", "notes": ["C2", "G1", "A1", "F1"] },
      "climax": { "pattern": "root_fifth", "notes": ["C2-G2", "G1-D2", "A1-E2", "F1-C2"] },
      "resolve":{ "pattern": "whole_notes", "notes": ["C2", "G1"] }
    },
    "strings": {
      "climax_only": true,
      "phrases": [
        { "notes": ["E5", "D5", "C5"], "rhythm": ["2n", "2n", "1n"], "role": "antecedent", "cadence": "half" },
        { "notes": ["G4", "A4", "B4", "C5"], "rhythm": ["4n", "4n", "4n", "2n."], "role": "consequent", "cadence": "authentic" }
      ]
    }
  },
  "transitions": {
    "intro_to_build": {
      "type": "fadeout",
      "bars_before": 1,
      "implementation": "Pad volume ramps from -10dB to -8dB over 1 bar. Piano enters with soft quarter notes. Bass enters on next downbeat."
    },
    "build_to_climax": {
      "type": "riser",
      "bars_before": 1,
      "implementation": "Piano increases note density from quarters to eighths over last bar. Strings fade in with 2-bar attack. Pad filter opens 1200Hz→3000Hz."
    },
    "climax_to_resolve": {
      "type": "fadeout",
      "bars_before": 1,
      "implementation": "Strings volume fades -14dB→-30dB over 1 bar. Bass releases to silence. Piano returns to whole-note spacing. Pad filter closes 3000Hz→1200Hz."
    }
  }
}
