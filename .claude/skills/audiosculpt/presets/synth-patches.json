{
  "_note": "FMSynth parameter database for acoustic instrument approximation. Used as FALLBACK when Tone.Sampler cannot load samples from sample-map.json. Each patch includes Tone.js constructor params + recommended effects. Updated with research-grade FM ratios from DX7/forum analysis. Patches with 'sampleSource' have a higher-quality sampled version available.",

  "piano-ep": {
    "label": "Electric Piano (DX7 Tine)",
    "sampleSource": null,
    "synth": "PolySynth(FMSynth)",
    "params": {
      "harmonicity": 15,
      "modulationIndex": 2,
      "oscillator": { "type": "sine" },
      "modulation": { "type": "square" },
      "envelope": { "attack": 0.001, "decay": 0.3, "sustain": 0.4, "release": 1.2 },
      "modulationEnvelope": { "attack": 0.002, "decay": 0.2, "sustain": 0.1, "release": 0.8 }
    },
    "effects": [{ "type": "Reverb", "config": { "decay": 2.0, "wet": 0.25 } }],
    "volume": -18,
    "notes": "1:15 ratio = metallic tine. modEnv decays faster than ampEnv = brightness fades while note rings."
  },

  "piano-wurlitzer": {
