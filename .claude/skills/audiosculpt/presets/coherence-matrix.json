  "visual_events": [
    "element-appear",
    "text-typing",
    "number-count",
    "card-flip",
    "scene-transition",
    "cta-final",
    "logo-reveal",
    "stat-progress"
  ],

  "style_selection_algorithm": {
    "description": "Deterministic style selection using feature vector from HTML analysis",
    "steps": [
      "1. Extract features: animDensity, aggressiveness, scenePace, colorEnergy, transitionIntensity",
      "2. Derive arousal: high (aggressiveness>0.5 OR animDensity>3 OR scenePace<3), medium (0.2-0.5, 3-5s), low (<0.2, >5s)",
      "3. Derive valence: dark (colorEnergy=dark AND aggressiveness>0.4), bright (colorEnergy=light OR aggressiveness<0.2), neutral (otherwise)",
      "4. Filter styles by mode_mapping[mode].soundtrack_styles",
      "5. Match arousal+valence to style feature_profile",
      "6. If multiple matches, pick lowest priority number"
    ]
  }
