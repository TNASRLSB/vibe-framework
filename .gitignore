node_modules/
__pycache__/
*.pyc
.venv/

# Orson engine build output
plugin/skills/orson/engine/dist/
plugin/skills/orson/engine/node_modules/
plugin/skills/orson/engine/audio/.venv/

# Orson background music tracks (downloaded on first use via
# plugin/skills/orson/engine/audio/download-library.sh). These are
# Mixkit CC0 tracks ~3.1-4.7 MB each — shipping them in git bloats the
# plugin from ~1 MB to ~42 MB for no functional benefit. audio-selector.ts
# already throws a clear error pointing to the download script when
# tracks are missing, so fresh installs get automatic guidance.
plugin/skills/orson/engine/audio/tracks/*.mp3

# Claude Code local state (project-local config and memory)
.claude/

# Preview files
*.preview.html
video-preview.html

# OS files
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────
# Internal-only directories — NOT distributed with the plugin
# Only `plugin/` and `.claude-plugin/marketplace.json` ship.
# ─────────────────────────────────────────────────────────

# Test infrastructure — dev only, not part of distributed product
/tests/

# Internal design specs and implementation plans
/docs/

# Research output: paper, experiments, datasets
/research/

# Third-party reference material (Claude Code source dump, etc.)
/vendor/

# Atomic decomposition manifests (per-task internal coordination files)
/.atomic-decomp/

# Internal reference material (user research dumps, competitor analyses, etc.)
# Entry was accidentally dropped during the 5.0.0 layout refactor (359b84b);
# restored in 5.5.1 to prevent accidental leaks on git add -A.
/references/
