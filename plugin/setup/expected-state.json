{
  "schemaVersion": 1,
  "version": "5.4.0",
  "envVarsOwned": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "SLASH_COMMAND_TOOL_CHAR_BUDGET": "50000",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "envVarsDeprecated": [
    "VIBE_INTEGRITY_MODE"
  ],
  "dataFilesDeprecated": [
    "tips-state.json",
    "dream",
    "learnings",
    "costs"
  ],
  "claudeMdLegacyTokens": [
    "reflect skill",
    "VIBE_GATE",
    "Completion Integrity",
    "Morpheus: Context Awareness",
    "Claude Operating System",
    "adapt-framework"
  ],
  "claudeMdManagedMarkerStart": "<!-- VIBE:managed-start -->",
  "claudeMdManagedMarkerEnd": "<!-- VIBE:managed-end -->",
  "markerFilePath": "~/.claude/vibe-configured",
  "thinkingFix": {
    "shellMarkerStart": "# >>> VIBE: thinking-display fix #49268 >>>",
    "shellMarkerEnd": "# <<< VIBE: thinking-display fix #49268 <<<",
    "vscodeWrapperSettingKey": "claudeCode.claudeProcessWrapper",
    "wrapperScriptRelpath": "scripts/cc-thinking-wrapper.sh"
  },
  "vibeHooks": [
    {
      "id": "read-discipline",
      "matcher": "Read",
      "event": "PreToolUse",
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/read-discipline.sh"
    },
    {
      "id": "read-before-edit",
      "matcher": "Edit|Write",
      "event": "PreToolUse",
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/read-before-edit.sh"
    }
  ],
  "skimPatternFlag": {
    "name": "VIBE_RG_SKIM_PATTERNS_ENABLED",
    "default": "0",
    "description": "Enables rhetoric-guard skim-tell patterns. Promote to default=1 in 5.4.1 only if field fire-rate <5%."
  }
}
