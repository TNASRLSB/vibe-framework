{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/setup-check.sh\"",
            "statusMessage": "VIBE: checking configuration..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/pre-tool-security.sh\"",
            "statusMessage": "VIBE: pre-execution security check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/post-edit-lint.sh\"",
            "statusMessage": "Lint check..."
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/security-quickscan.sh\"",
            "statusMessage": "Security scan..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/failure-reset.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/pre-compact-save.sh\"",
            "statusMessage": "Saving session state..."
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/failure-loop-detect.sh\"",
            "statusMessage": "Tracking failures..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/rhetoric-guard.sh\"",
            "statusMessage": "VIBE: rhetoric check..."
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/atomic-enforcement.sh\"",
            "statusMessage": "VIBE: atomic verification..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/agent-memory-sync.sh\"",
            "statusMessage": "VIBE: syncing agent memory..."
          }
        ]
      }
    ]
  }
}
